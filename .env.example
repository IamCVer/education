# Copy this file to .env for local deployment.
# Do not commit real keys or production passwords.

# LLM / DashScope
QWEN_API_KEY=
DASHSCOPE_API_KEY=
NEXT_PUBLIC_DASHSCOPE_KEY=
NEXT_PUBLIC_OPENROUTER_API_KEY=
QWEN_TURBO_MODEL_NAME=qwen-turbo
QWEN_MAX_MODEL_NAME=qwen-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_VOSK_SERVICE_URL=http://localhost:3002/transcribe

# Aliyun OSS, used by the video module
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=education-videos

# XFYun PPT generation, used by the teacher assistant module
XFYUN_PPT_APP_ID=
XFYUN_PPT_API_SECRET=
XFYUN_PPT_BASE_URL=

# MediaCMS / Mattermost optional integration tokens
MEDIACMS_ADMIN_TOKEN=
MEDIACMS_ADMIN_PASSWORD=admin123
MEDIACMS_SECRET_KEY=change-this-secret-key-in-production
MATTERMOST_TOKEN=
MATTERMOST_PERSONAL_ACCESS_TOKEN=
MATTERMOST_BOT_TOKEN=

# Optional Google Maps key for manage-system Maps page
VUE_APP_GOOGLE_MAPS_API_KEY=
VUE_APP_API_BASE_URL=http://localhost:8000
VUE_APP_WS_URL=http://localhost:8000
